{
  "name": "@martsallan/goal-opencode",
  "version": "0.3.0",
  "type": "module",
  "description": "Long-running goal mode for OpenCode with auto-continuation, auto-clear on completion, and a goal sidebar widget",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tui": "./src/tui.tsx"
  },
  "files": [
