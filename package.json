    "!src/**/*.test.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "plugin",
    "goal",
    "sidebar",
    "tui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/martsallan/goal-opencode.git"
  },
  "homepage": "https://github.com/martsallan/goal-opencode#readme",
  "bugs": {
    "url": "https://github.com/martsallan/goal-opencode/issues"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.16.2",
    "@opencode-ai/sdk": "^1.16.2"
  },
  "peerDependencies": {
    "@opentui/core": ">=0.3.2",
    "@opentui/keymap": ">=0.3.2",
    "@opentui/solid": ">=0.3.2",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@opentui/core": "0.3.2",
    "@opentui/keymap": "0.3.2",
    "@opentui/solid": "0.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.8.0",
    "solid-js": "1.9.12",
    "typescript": "^5.9.3"
  }
